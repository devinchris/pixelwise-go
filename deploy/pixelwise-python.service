[Unit]
Description=PixelWise API
After=network.target postgresql.service

[Service]
User=produser
WorkingDirectory=/opt/pixelwise-go
EnvironmentFile=/opt/pixelwise-go/.env
ExecStart=/opt/pixelwise-go/.venv/bin/uvicorn \
app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
